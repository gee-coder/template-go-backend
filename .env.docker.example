# Copy this file to .env.docker before running:
# docker compose --env-file .env.docker up -d --build

# Host ports
MYSQL_PORT=3306
REDIS_PORT=6379
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
GATEWAY_PORT=8080

# MySQL
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=nex_template
MYSQL_USER=nex
MYSQL_PASSWORD=nex123456

# Redis
REDIS_PASSWORD=

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=nex-assets

# App
APP_APP_NAME=template-go-backend
APP_APP_ENV=docker
APP_APP_DEBUG=false
APP_APP_UPLOADDIR=./storage/uploads

# Auth switches
APP_AUTH_ENABLEEMAILLOGIN=true
APP_AUTH_ENABLEPHONELOGIN=true
APP_AUTH_ENABLEEMAILREGISTRATION=true
APP_AUTH_ENABLEPHONEREGISTRATION=true
APP_AUTH_ENABLETWOFACTOR=false

# Database and Redis
APP_DATABASE_DSN=nex:nex123456@tcp(mysql:3306)/nex_template?charset=utf8mb4&parseTime=True&loc=Local
APP_REDIS_ADDR=redis:6379
APP_REDIS_PASSWORD=
APP_REDIS_DB=0
APP_REDIS_KEYPREFIX=nex:template:

# JWT
APP_JWT_ISSUER=nex-template
APP_JWT_SECRET=please-change-me

# Storage
# Supported providers: local, minio, aliyun_oss, huawei_obs
APP_STORAGE_PROVIDER=minio
APP_STORAGE_LOCAL_PUBLICBASEURL=/uploads

APP_STORAGE_MINIO_ENDPOINT=minio:9000
APP_STORAGE_MINIO_ACCESSKEYID=minioadmin
APP_STORAGE_MINIO_ACCESSKEYSECRET=minioadmin
APP_STORAGE_MINIO_BUCKET=nex-assets
APP_STORAGE_MINIO_USESSL=false
APP_STORAGE_MINIO_PUBLICBASEURL=http://127.0.0.1:9000/nex-assets
APP_STORAGE_MINIO_ROOTPATH=template/docker

APP_STORAGE_ALIYUNOSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
APP_STORAGE_ALIYUNOSS_REGION=cn-hangzhou
APP_STORAGE_ALIYUNOSS_ACCESSKEYID=
APP_STORAGE_ALIYUNOSS_ACCESSKEYSECRET=
APP_STORAGE_ALIYUNOSS_BUCKET=
APP_STORAGE_ALIYUNOSS_PUBLICBASEURL=
APP_STORAGE_ALIYUNOSS_ROOTPATH=template/docker

APP_STORAGE_HUAWEIOBS_ENDPOINT=https://obs.cn-north-4.myhuaweicloud.com
APP_STORAGE_HUAWEIOBS_ACCESSKEYID=
APP_STORAGE_HUAWEIOBS_ACCESSKEYSECRET=
APP_STORAGE_HUAWEIOBS_BUCKET=
APP_STORAGE_HUAWEIOBS_PUBLICBASEURL=
APP_STORAGE_HUAWEIOBS_ROOTPATH=template/docker

# SMS
# Supported provider today: mock
# Reserved but not enabled in the template yet: aliyun, huawei
APP_SMS_PROVIDER=mock
APP_SMS_MOCK_REVEALCODE=true
APP_SMS_MOCK_FIXEDCODE=
APP_SMS_ALIYUN_ENDPOINT=dysmsapi.aliyuncs.com
APP_SMS_ALIYUN_ACCESSKEYID=
APP_SMS_ALIYUN_ACCESSKEYSECRET=
APP_SMS_ALIYUN_SIGNNAME=
APP_SMS_ALIYUN_TEMPLATECODE=
APP_SMS_HUAWEI_ENDPOINT=
APP_SMS_HUAWEI_APPKEY=
APP_SMS_HUAWEI_APPSECRET=
APP_SMS_HUAWEI_SENDER=
APP_SMS_HUAWEI_TEMPLATEID=
APP_SMS_HUAWEI_SIGNATURE=

# Mail
# Supported providers: mock, smtp
APP_MAIL_PROVIDER=mock
APP_MAIL_FROMNAME=Nex Console
APP_MAIL_FROMADDRESS=no-reply@example.com
APP_MAIL_MOCK_REVEALCODE=true
APP_MAIL_MOCK_FIXEDCODE=
APP_MAIL_SMTP_HOST=smtp.example.com
APP_MAIL_SMTP_PORT=587
APP_MAIL_SMTP_USERNAME=
APP_MAIL_SMTP_PASSWORD=
APP_MAIL_SMTP_USETLS=true
